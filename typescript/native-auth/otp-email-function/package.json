  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@azure/functions": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "rimraf": "^5.0.0",
    "typescript": "^5"
  }
}
